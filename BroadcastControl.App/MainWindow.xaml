<!--
    GUI의 실제 화면 구조를 정의하는 XAML 파일이다.
    상단 바, 좌측 모터/각도 패널, 중앙 EO/IR 카메라 화면, 하단 Network/System Status 영역,
    우측 분석/로그 패널과 설정 drawer의 배치를 담당한다.
    버튼 동작과 네트워크 이벤트 처리는 MainWindow.xaml.cs와 MainViewModel.cs에 연결되어 있다.
-->
<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="LIG DNA GUI"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DropShadowEffect x:Key="SoftPanelShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="TopBarShadow"
                          BlurRadius="6"
                          ShadowDepth="0"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="DrawerShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.10"
                          Color="#66000000" />

        <Style x:Key="GlassCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Effect" Value="{StaticResource SoftPanelShadow}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="OverlayCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style x:Key="TopBarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarSmallButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarCompactSlider" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ArrowButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="MotorPadButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#33475663" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#55475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#66475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineRotateButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#33475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaybackIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#22313A46" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#55475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SettingsActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawerItemBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="SettingsCompactLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="SettingsCompactTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawerItemBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsCompactComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawerItemBorderBrush}" />
            <Setter Property="TextElement.Foreground" Value="#FF111827" />
            <Setter Property="TextElement.FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                            Padding="8,4"
                            FontSize="14"
                            Foreground="#FF111827" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FF111827" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="8,4" />
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZoomSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid x:Name="RootLayout"
          Width="1600"
          Height="900">
            <!-- 전체 창의 최상위 컨테이너.
             본문 패널과 설정 드로어를 이 Grid 안에 배치한다. -->
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Rectangle Grid.RowSpan="2"
                       Margin="-4"
                       IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <DynamicResource ResourceKey="WindowBackdropBrush" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- 상단 바:
                 전원 종료, 녹화 상태, 밝기/대조비, 모드 전환, 설정 버튼을 배치한다. -->
                <Border Grid.Row="0"
                    Visibility="Collapsed"
                    Style="{StaticResource GlassCardBorder}"
                    CornerRadius="2"
                    Effect="{StaticResource TopBarShadow}">
                    <Grid Margin="14,10,42,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="152" />
                            <ColumnDefinition Width="152" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            MinWidth="126"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource TopBarButton}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16"
                                     Height="16"
                                     Margin="0,0,8,0"
                                     Fill="{Binding CurrentThreatBrush}" />
                                <TextBlock Text="{Binding PowerButtonText}" />
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                MinWidth="128">
                            <StackPanel Orientation="Horizontal"
                                    Opacity="{Binding RecordingIndicatorOpacity}">
                                <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding RecordingIndicatorBrush}" />
                                <TextBlock VerticalAlignment="Center"
                                       Foreground="{Binding RecordingTextBrush}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Text="{Binding Text[RecordingOn]}" />
                            </StackPanel>
                            <StackPanel Margin="0,3,0,0"
                                    Orientation="Horizontal"
                                    Opacity="{Binding JetsonConnectionOpacity}">
                                <Ellipse Width="9"
                                     Height="9"
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding JetsonConnectionBrush}" />
                                <TextBlock VerticalAlignment="Center"
                                       Foreground="{Binding JetsonConnectionBrush}"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Text="{Binding JetsonConnectionText}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Button HorizontalAlignment="Left"
                                Command="{Binding ResetBrightnessCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding BrightnessText}" />
                            <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center">
                            <Button HorizontalAlignment="Left"
                                Command="{Binding ResetContrastCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding ContrastText}" />
                            <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                        </StackPanel>

                        <Button Grid.Column="4"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="&#xC790;&#xB3D9;"
                            IsHitTestVisible="{Binding CanSelectAutoMode}"
                            Opacity="{Binding AutoModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="{Binding Text[AutoMode]}" />

                        <Button Grid.Column="5"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="&#xC218;&#xB3D9;"
                            IsHitTestVisible="{Binding CanSelectManualMode}"
                            Opacity="{Binding ManualModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="{Binding Text[ManualMode]}" />

                        <Button Grid.Column="6"
                            Width="84"
                            Margin="0,0,12,0"
                            Padding="10,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Style="{StaticResource TopBarSmallButton}"
                            Opacity="{Binding ManualRecordingButtonOpacity}"
                            IsEnabled="{Binding IsManualMode}"
                            Command="{Binding ToggleManualRecordingCommand}"
                            Content="{Binding ManualRecordingButtonText}" />

                        <Button Grid.Column="7"
                            Width="54"
                            Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource TopBarButton}">
                            <materialDesign:PackIcon Kind="Menu"
                                                 Width="24"
                                                 Height="24" />
                        </Button>
                    </Grid>
                </Border>

                <!-- 본문 영역:
                 왼쪽 카메라 화면과 오른쪽 시스템 현황/상황 분석/시스템 로그 패널을 배치한다. -->
                <Grid Grid.Row="1"
                  Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                      Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="74" />
                            <RowDefinition Height="150" />
                            <RowDefinition Height="128" />
                            <RowDefinition Height="138" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                            Margin="0,0,0,12"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource TopBarButton}">
                            <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PowerButtonText}" />
                                <Ellipse Width="10"
                                     Height="10"
                                     Margin="8,1,0,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding CurrentThreatBrush}" />
                            </StackPanel>
                        </Button>

                        <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            Background="#FF05070A">
                            <Grid Margin="12">
                                <Border Width="108"
                                    Height="25"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource OverlayCardBorder}"
                                    BorderThickness="0"
                                    Padding="7,3">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                               Text="CAM 1"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                        <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Tag="CAM 1"
                                            Click="RotateAuxCameraButton_OnClick"
                                            Style="{StaticResource InlineRotateButton}">
                                            <materialDesign:PackIcon Kind="RotateRight" Width="12" Height="12" />
                                        </Button>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                            Style="{StaticResource GlassCardBorder}">
                            <Grid Margin="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Text="{Binding Text[MotorPosition]}" />
                                    <Button Grid.Column="1"
                                        Width="58"
                                        Height="23"
                                        Padding="6,1"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Command="{Binding ToggleMotorDetailsCommand}"
                                        Style="{StaticResource TopBarSmallButton}"
                                        Content="{Binding Text[Details]}" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                        Margin="0,0,4,0"
                                        Padding="7,5"
                                        Background="{DynamicResource OverlayPanelBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   Text="Pan" />
                                            <TextBlock Grid.Row="1"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   Text="{Binding PanMotorPositionText}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1"
                                        Margin="4,0,0,0"
                                        Padding="7,5"
                                        Background="{DynamicResource OverlayPanelBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   Text="Tilt" />
                                            <TextBlock Grid.Row="1"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   Text="{Binding TiltMotorPositionText}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                            Margin="0,12,0,0"
                            Style="{StaticResource GlassCardBorder}">
                            <Grid Margin="10"
                              IsEnabled="{Binding CanUseMotorTargetControls}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Text="{Binding Text[MotorTarget]}" />
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="62" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Text="Pan" />
                                    <TextBox Grid.Column="1"
                                         Height="29"
                                         Padding="5,3"
                                         FontSize="12"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Background="{DynamicResource OverlayPanelBrush}"
                                         BorderBrush="{DynamicResource PanelBorderBrush}"
                                         Text="{Binding MotorTargetPanText, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SendMotorTargetCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Text="Tilt" />
                                    <TextBox Grid.Column="4"
                                         Height="29"
                                         Padding="5,3"
                                         FontSize="12"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Background="{DynamicResource OverlayPanelBrush}"
                                         BorderBrush="{DynamicResource PanelBorderBrush}"
                                         Text="{Binding MotorTargetTiltText, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SendMotorTargetCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </Grid>
                                <Button Grid.Row="2"
                                    Height="29"
                                    Margin="0,12,0,0"
                                    Command="{Binding SendMotorTargetCommand}"
                                    Style="{StaticResource TopBarSmallButton}"
                                    Content="Enter" Click="Button_Click_2" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                            Margin="0,12,0,0"
                            Style="{StaticResource GlassCardBorder}">
                            <Grid Margin="10"
                              VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="127*"/>
                                    <ColumnDefinition Width="89*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Text="{Binding Text[MotorSpeed]}" />
                                <Grid Grid.Row="1" Margin="0,10,0,0" Grid.ColumnSpan="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Height="28" Padding="6,1" FontSize="14" FontWeight="Bold" HorizontalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Auto:Reset" Style="{StaticResource TopBarSmallButton}" Content="Scan" />
                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="7" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="7" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Height="31" Padding="0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Auto:-1" Style="{StaticResource TopBarButton}" Content="-" />
                                            <Border Grid.Column="2" Height="33" Background="{DynamicResource OverlayPanelBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="2">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" FontWeight="Bold" Text="{Binding AutoMotorAngleSizeText}" />
                                            </Border>
                                            <Button Grid.Column="4" Height="31" Padding="0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Auto:1" Style="{StaticResource TopBarButton}" Content="+" />
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Height="28" Padding="6,1" FontSize="14" FontWeight="Bold" HorizontalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Manual:Reset" Style="{StaticResource TopBarSmallButton}" Content="Manual" />
                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="7" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="7" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Height="31" Padding="0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Manual:-1" Style="{StaticResource TopBarButton}" Content="-" />
                                            <Border Grid.Column="2" Height="33" Background="{DynamicResource OverlayPanelBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="2">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" FontWeight="Bold" Text="{Binding ManualMotorAngleSizeText}" />
                                            </Border>
                                            <Button Grid.Column="4" Height="31" Padding="0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdjustMotorStepCommand}" CommandParameter="Manual:1" Style="{StaticResource TopBarButton}" Content="+" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                                <TextBlock
                                       Margin="121,0,0,161"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold" Grid.RowSpan="2" Width="128" Grid.ColumnSpan="2"><Run Text="Scan : + / -"/><LineBreak/><Run Text="Manual : Ctrl + / -"/><LineBreak/><Run/></TextBlock>
                                <Border Grid.Row="1"
                                    Margin="0,175,0,0"
                                    Padding="8,8"
                                    Background="{DynamicResource OverlayPanelBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Opacity="{Binding MotorControlsOpacity}"
                                    IsEnabled="{Binding CanUseMotorControls}" Grid.ColumnSpan="2" Grid.RowSpan="3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Text="{Binding Text[MotorControl]}" />
                                        <Grid Grid.Row="1"
                                          Width="128"
                                          Height="104"
                                          Margin="0,8,0,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="36" />
                                                <RowDefinition Height="32" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="42" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="MotorPadUpButton" Grid.Row="0" Grid.Column="1" Tag="Up" PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp" MouseLeave="MotorButton_OnMouseLeave" Style="{StaticResource MotorPadButton}">
                                                <materialDesign:PackIcon Kind="ArrowUpBold" Width="15" Height="15" />
                                            </Button>
                                            <Button x:Name="MotorPadLeftButton" Grid.Row="1" Grid.Column="0" Tag="Left" PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp" MouseLeave="MotorButton_OnMouseLeave" Style="{StaticResource MotorPadButton}">
                                                <materialDesign:PackIcon Kind="ArrowLeftBold" Width="15" Height="15" />
                                            </Button>
                                            <Button x:Name="MotorPadCenterButton" Grid.Row="1" Grid.Column="1" Tag="Center" PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp" MouseLeave="MotorButton_OnMouseLeave" Style="{StaticResource MotorPadButton}">
                                                <Ellipse Width="12" Height="12" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.6" Fill="Transparent" />
                                            </Button>
                                            <Button x:Name="MotorPadRightButton" Grid.Row="1" Grid.Column="2" Tag="Right" PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp" MouseLeave="MotorButton_OnMouseLeave" Style="{StaticResource MotorPadButton}">
                                                <materialDesign:PackIcon Kind="ArrowRightBold" Width="15" Height="15" />
                                            </Button>
                                            <Button x:Name="MotorPadDownButton" Grid.Row="2" Grid.Column="1" Tag="Down" PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp" MouseLeave="MotorButton_OnMouseLeave" Style="{StaticResource MotorPadButton}">
                                                <materialDesign:PackIcon Kind="ArrowDownBold" Width="15" Height="15" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 카메라 패널:
                     EO 주 화면, IR 인셋 화면, 모터 조작 버튼, 전자 줌 UI를 포함한다. -->
                    <Grid Grid.Column="1"
                      Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <Border x:Name="CameraPanel"
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        Style="{StaticResource GlassCardBorder}"
                        BorderBrush="#00000000"
                        CornerRadius="2">
                            <Grid x:Name="CameraViewport"
                          ClipToBounds="True"
                          SizeChanged="CameraViewport_OnSizeChanged"
                          MouseLeftButtonDown="CameraViewport_OnMouseLeftButtonDown"
                          MouseWheel="CameraViewport_OnMouseWheel"
                          MouseMove="CameraViewport_OnMouseMove"
                          MouseLeftButtonUp="CameraViewport_OnMouseLeftButtonUp">
                                <Rectangle Fill="{DynamicResource SurfaceAltBrush}" />

                                <!-- LargeFeedImage는 크게 보여줄 카메라 영상 바인딩이다.
                             EO/IR 전환 상태에 따라 표시 영상이 달라진다. -->
                                <Image Source="{Binding LargeFeedImage}"
                               Margin="0"
                               Stretch="{Binding LargeFeedStretch}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="{Binding LargeFeedRotationAngle}" />
                                            <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                                    ScaleY="{Binding LargeFeedScale}" />
                                            <TranslateTransform X="{Binding ZoomTransformX}"
                                                        Y="{Binding ZoomTransformY}" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>

                                <!-- 좌상단 라벨은 현재 큰 화면의 카메라 종류를 표시한다. -->
                                <Border Margin="16,12,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Style="{StaticResource OverlayCardBorder}"
                                BorderThickness="0"
                                CornerRadius="2"
                                Padding="8,4">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Text="{Binding LargeFeedTitle}" />
                                        <Button DockPanel.Dock="Right"
                                        Margin="10,0,0,0"
                                        Click="RotateLargeFeedButton_OnClick"
                                        Style="{StaticResource InlineRotateButton}">
                                            <materialDesign:PackIcon Kind="RotateRight" Width="14" Height="14" />
                                        </Button>
                                    </DockPanel>
                                </Border>

                                <!-- 전자 줌 미니맵.
                             확대 중 전체 화면 대비 현재 보고 있는 영역을 작은 지도처럼 표시한다. -->
                                <Border Width="152"
                                Height="108"
                                Margin="18,0,0,20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource OverlayCardBorder}"
                                CornerRadius="2"
                                Visibility="{Binding ShowZoomMiniMap, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid Margin="10">
                                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Text="{Binding Text[ZoomMiniMap]}" />
                                        <Canvas Width="130"
                                        Height="74"
                                        Margin="0,18,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                            <Rectangle Width="130"
                                               Height="74"
                                               Fill="#55333F4D"
                                               Stroke="#FF64748B"
                                               StrokeThickness="1" />
                                            <Rectangle Width="{Binding MiniMapViewportWidth}"
                                               Height="{Binding MiniMapViewportHeight}"
                                               Canvas.Left="{Binding MiniMapViewportLeft}"
                                               Canvas.Top="{Binding MiniMapViewportTop}"
                                               Fill="#3300FFAA"
                                               Stroke="{DynamicResource AccentBrush}"
                                               StrokeThickness="1.5" />
                                        </Canvas>
                                    </Grid>
                                </Border>

                                <Canvas x:Name="DetectionOverlayCanvas"
                                Width="{Binding ElementName=CameraViewport, Path=ActualWidth}"
                                Height="{Binding ElementName=CameraViewport, Path=ActualHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="5"
                                ClipToBounds="True"
                                RenderTransformOrigin="0.5,0.5"
                                IsHitTestVisible="False">
                                    <Canvas.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                                    ScaleY="{Binding LargeFeedScale}" />
                                            <TranslateTransform X="{Binding ZoomTransformX}"
                                                        Y="{Binding ZoomTransformY}" />
                                        </TransformGroup>
                                    </Canvas.RenderTransform>
                                </Canvas>

                                <!-- IR/EO 인셋 화면:
                             작은 화면 클릭 시 큰 화면과 전환되는 입력 영역이다. -->
                                <Button Width="168"
                                Height="124"
                                Margin="0,8,26,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Command="{Binding SwapFeedsCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                                    <!-- IR 인셋은 영상만 보이도록 내부 배경과 테두리를 제거한다. -->
                                    <Border Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="1">
                                        <Grid ClipToBounds="True">
                                            <Image Source="{Binding InsetFeedImage}"
                                           Stretch="{Binding InsetFeedStretch}"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <RotateTransform Angle="{Binding InsetFeedRotationAngle}" />
                                                </Image.RenderTransform>
                                            </Image>
                                            <Border Margin="10,10,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Style="{StaticResource OverlayCardBorder}"
                                             BorderThickness="0"
                                             CornerRadius="2"
                                             Padding="7,3">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Text="{Binding InsetFeedTitle}" />
                                                    <Button DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Click="RotateInsetFeedButton_OnClick"
                                                    Style="{StaticResource InlineRotateButton}">
                                                        <materialDesign:PackIcon Kind="RotateRight" Width="12" Height="12" />
                                                    </Button>
                                                </DockPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>

                                <!-- 모터 방향 버튼:
                             수동 모드에서 표시되며 실제 모터 제어 명령과 연결된다. -->
                                <Grid Margin="0,0,24,26"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,0,0,8"
                                    Padding="12,5"
                                    Background="#DD05070A"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                        <TextBlock HorizontalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Text="{Binding Text[MotorControl]}" />
                                    </Border>

                                    <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Tag="Up"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp"
                                    MouseLeave="MotorButton_OnMouseLeave"
                                    Style="{StaticResource ArrowButton}">
                                        <materialDesign:PackIcon Kind="ArrowUpBold" Width="20" Height="20" />
                                    </Button>
                                    <Button Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,6,6,6"
                                    Tag="Left"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp"
                                    MouseLeave="MotorButton_OnMouseLeave"
                                    Style="{StaticResource ArrowButton}">
                                        <materialDesign:PackIcon Kind="ArrowLeftBold" Width="20" Height="20" />
                                    </Button>
                                    <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,6,0,6"
                                    Tag="Center"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp"
                                    MouseLeave="MotorButton_OnMouseLeave"
                                    Style="{StaticResource ArrowButton}">
                                        <Ellipse Width="16"
                                         Height="16"
                                         Stroke="{DynamicResource PrimaryTextBrush}"
                                         StrokeThickness="2"
                                         Fill="Transparent" />
                                    </Button>
                                    <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="6,6,0,6"
                                    Tag="Right"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp"
                                    MouseLeave="MotorButton_OnMouseLeave"
                                    Style="{StaticResource ArrowButton}">
                                        <materialDesign:PackIcon Kind="ArrowRightBold" Width="20" Height="20" />
                                    </Button>
                                    <Button Grid.Row="3"
                                    Grid.Column="1"
                                    Tag="Down"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    PreviewMouseLeftButtonDown="MotorButton_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="MotorButton_OnPreviewMouseLeftButtonUp"
                                    MouseLeave="MotorButton_OnMouseLeave"
                                    Style="{StaticResource ArrowButton}">
                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="20" Height="20" />
                                    </Button>
                                </Grid>

                                <!-- 전자 줌 패널은 배경이 과하게 길어 보이지 않도록 고정 폭으로 묶는다. -->
                                <!-- 전자 줌 패널:
                             줌 리셋 버튼, 배율 슬라이더, 현재 배율 텍스트를 한 묶음으로 표시한다. -->
                                <Border Margin="182,0,220,18"
                                Padding="10,7"
                                Width="340"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource OverlayCardBorder}"
                                CornerRadius="2"
                                Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 전자 줌 라벨은 리셋 버튼이며 클릭 시 x1.0 기본 배율로 복귀한다. -->
                                        <Button VerticalAlignment="Center"
                                        Command="{Binding ResetZoomCommand}"
                                        Style="{StaticResource TopBarSmallButton}"
                                        Content="{Binding Text[CamZoom]}" />
                                        <Slider Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="1"
                                        Maximum="4"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="False"
                                        Value="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanUseZoomControls}"
                                        Style="{StaticResource ZoomSliderStyle}" />
                                        <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13"
                                           Text="{Binding ZoomLevelText}" />
                                    </Grid>
                                </Border>

                                <Border Margin="14,0,14,14"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="#CC1B2431"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Panel.ZIndex="8"
                                Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="44" />
                                            <RowDefinition Height="44" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,12,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                            <Button Width="88"
                                            Margin="0,0,10,0"
                                            Command="{Binding ResetZoomCommand}"
                                            Style="{StaticResource TopBarSmallButton}"
                                        Content="{Binding Text[CamZoom]}" />
                                            <Slider Width="210"
                                            Minimum="1"
                                            Maximum="4"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="False"
                                            Value="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding CanUseZoomControls}" />
                                            <TextBlock Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="12"
                                               Text="{Binding ZoomLevelText}" />
                                        </StackPanel>

                                        <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="4,0"
                                        Command="{Binding SetModeCommand}"
                                        CommandParameter="&#xC790;&#xB3D9;"
                                        IsHitTestVisible="{Binding CanSelectAutoMode}"
                                        Opacity="{Binding AutoModeOpacity}"
                                        Style="{StaticResource TopBarButton}"
                                        Content="{Binding Text[AutoMode]}" />
                                        <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="4,0"
                                        Command="{Binding SetModeCommand}"
                                        CommandParameter="&#xC218;&#xB3D9;"
                                        IsHitTestVisible="{Binding CanSelectManualMode}"
                                        Opacity="{Binding ManualModeOpacity}"
                                        Style="{StaticResource TopBarButton}"
                                        Content="{Binding Text[ManualMode]}" />

                                        <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,12,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                            <Button Width="88"
                                            Margin="0,0,10,0"
                                            Command="{Binding ResetBrightnessCommand}"
                                            Style="{StaticResource TopBarSmallButton}"
                                            Content="{Binding BrightnessText}" />
                                            <Slider Width="180"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding IsSystemPoweredOn}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            Margin="4,0,10,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                            <Button Width="88"
                                            Margin="0,0,10,0"
                                            Command="{Binding ResetContrastCommand}"
                                            Style="{StaticResource TopBarSmallButton}"
                                            Content="{Binding ContrastText}" />
                                            <Slider Width="145"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding IsSystemPoweredOn}" />
                                        </StackPanel>

                                        <Button Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="4,0"
                                        Command="{Binding ToggleManualRecordingCommand}"
                                        Opacity="{Binding ManualRecordingButtonOpacity}"
                                        IsEnabled="{Binding IsManualMode}"
                                        Style="{StaticResource TopBarButton}"
                                        Content="{Binding ManualRecordingButtonText}" />

                                        <StackPanel Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="4"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            MinWidth="120">
                                            <StackPanel Orientation="Horizontal"
                                                Opacity="{Binding RecordingIndicatorOpacity}">
                                                <Ellipse Width="8"
                                                 Height="8"
                                                 Margin="0,0,6,0"
                                                 Fill="{Binding RecordingIndicatorBrush}" />
                                                <TextBlock VerticalAlignment="Center"
                                                   Foreground="{Binding RecordingTextBrush}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Text[RecordingStatus]}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,3,0,0"
                                                Orientation="Horizontal"
                                                Opacity="{Binding JetsonConnectionOpacity}">
                                                <Ellipse Width="8"
                                                 Height="8"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding JetsonConnectionBrush}" />
                                                <TextBlock VerticalAlignment="Center"
                                                   Foreground="{Binding JetsonConnectionBrush}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Text="{Binding JetsonConnectionText}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 오른쪽 정보 패널:
                     시스템 현황, 상황 분석, 시스템 로그를 세로로 배치한다. -->
                        <Border Grid.Row="1"
                            Padding="14,12"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.0*" />
                                    <ColumnDefinition Width="1.0*" />
                                    <ColumnDefinition Width="1.0*" />
                                    <ColumnDefinition Width="1.32*" />
                                    <ColumnDefinition Width="1.43*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Width="92" Margin="0,0,10,0" Command="{Binding ResetContrastCommand}" Style="{StaticResource TopBarSmallButton}" Content="{Binding ContrastText}" />
                                    <Slider Width="220" Minimum="0" Maximum="100" Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSystemPoweredOn}" Style="{StaticResource TopBarCompactSlider}" />
                                </StackPanel>

                                <Button Grid.Row="0" Grid.Column="1" Margin="6,18,6,45" Command="{Binding SetModeCommand}" CommandParameter="&#xC790;&#xB3D9;" IsHitTestVisible="{Binding CanSelectAutoMode}" Opacity="{Binding AutoModeOpacity}" Style="{StaticResource TopBarButton}" Content="{Binding Text[AutoMode]}" Grid.RowSpan="2" />
                                <Button Grid.Row="0" Grid.Column="2" Margin="6,18,6,45" Command="{Binding SetModeCommand}" CommandParameter="&#xC218;&#xB3D9;" IsHitTestVisible="{Binding CanSelectManualMode}" Opacity="{Binding ManualModeOpacity}" Style="{StaticResource TopBarButton}" Content="{Binding Text[ManualMode]}" Click="Button_Click" Grid.RowSpan="2" />

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,6,0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Width="92" Margin="0,0,10,0" Command="{Binding ResetBrightnessCommand}" Style="{StaticResource TopBarSmallButton}" Content="{Binding BrightnessText}" />
                                    <Slider Width="220" Minimum="0" Maximum="100" Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSystemPoweredOn}" Style="{StaticResource TopBarCompactSlider}" />
                                </StackPanel>

                                <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding ResetZoomCommand}" Style="{StaticResource TopBarSmallButton}" Content="{Binding Text[CamZoom]}" />
                                    <Slider Grid.Column="2" Minimum="1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanUseZoomControls}" Style="{StaticResource TopBarCompactSlider}" />
                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Right" Text="{Binding ZoomLevelText}" Grid.ColumnSpan="2" Margin="3,0,7,0" />
                                </Grid>

                                <Button Grid.Row="1"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Margin="6,43,6,19"
                                    Command="{Binding ToggleTrackingModeCommand}"
                                    Opacity="{Binding TrackingModeOpacity}"
                                    Style="{StaticResource TopBarButton}"
                                    Content="{Binding TrackingModeText}" />

                                <Border Grid.Row="0"
                                    Grid.RowSpan="3"
                                    Grid.Column="3"
                                    Margin="6,0"
                                    Padding="8,6"
                                    Background="{DynamicResource OverlayPanelBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   Text="{Binding Text[NetworkSettings]}" />
                                            <Button Grid.Column="1"
                                                Width="48"
                                                Height="24"
                                                Margin="6,0,0,0"
                                                Padding="4,0"
                                                FontSize="11"
                                                Click="SaveNetworkSettingsButton_OnClick"
                                                Style="{StaticResource TopBarSmallButton}"
                                                Content="{Binding Text[Save]}" />
                                        </Grid>
                                        <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Text[JetsonIp]}"
                                                Style="{StaticResource SettingsCompactLabel}" />
                                            <TextBox x:Name="JetsonHostTextBox"
                                                Height="28"
                                                Padding="6,3"
                                                FontSize="12"
                                                Style="{StaticResource SettingsCompactTextBox}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Text[PcIp]}"
                                                Style="{StaticResource SettingsCompactLabel}" />
                                            <ComboBox x:Name="PcGuiHostComboBox"
                                                Height="28"
                                                Padding="6,2"
                                                FontSize="12"
                                                IsEditable="True"
                                                Style="{StaticResource SettingsCompactComboBox}">
                                                <ComboBox.Resources>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Foreground" Value="#FF111827" />
                                                        <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
                                                        <Setter Property="CaretBrush" Value="#FF111827" />
                                                        <Setter Property="FontSize" Value="12" />
                                                        <Setter Property="Padding" Value="6,3" />
                                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                                    </Style>
                                                </ComboBox.Resources>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="4" Margin="6,0,0,0" Padding="10,8" Background="{DynamicResource OverlayPanelBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="2">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" FontSize="19" FontWeight="Bold" Text="{Binding Text[SystemStatus]}" />
                                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" FontWeight="Bold" Text="{Binding CurrentThreatText}" />
                                            <Ellipse Width="13" Height="13" Margin="7,3,0,0" VerticalAlignment="Top" Fill="{Binding CurrentThreatBrush}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" Text="{Binding PrimaryTargetShortText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="1.44*" />
                            <RowDefinition Height="1.56*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                          Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="54" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MinWidth="132">
                                <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Opacity="{Binding RecordingIndicatorOpacity}">
                                    <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding RecordingIndicatorBrush}" />
                                    <TextBlock
                                           Foreground="{Binding RecordingTextBrush}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Text="{Binding Text[RecordingOn]}" />
                                </StackPanel>
                                <StackPanel Margin="0,3,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Opacity="{Binding JetsonConnectionOpacity}">
                                    <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding JetsonConnectionBrush}" />
                                    <TextBlock
                                           Foreground="{Binding JetsonConnectionBrush}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Text="{Binding JetsonConnectionText}" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="2"
                                Click="OpenRecordedVideosButton_OnClick"
                                Style="{StaticResource TopBarButton}"
                                Content="{Binding Text[RecordedData]}" />
                            <Button Grid.Column="4"
                                Command="{Binding ToggleSettingsCommand}"
                                Style="{StaticResource TopBarButton}"
                                Padding="0" Click="Button_Click_1">
                                <materialDesign:PackIcon Kind="Cog" Width="22" Height="22" />
                            </Button>
                        </Grid>

                        <!-- 시스템 현황 패널:
                         위험 등급과 주 탐지체처럼 즉시 필요한 상태만 표시한다. -->
                        <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,12,18,12"
                            Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Style="{StaticResource PanelTitle}" Text="{Binding Text[SystemStatus]}" />
                                <StackPanel Margin="0,10,0,5"
                                        Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Text="{Binding CurrentThreatText}" />
                                    <Ellipse Width="14"
                                        Height="14"
                                        Margin="5,5,10,0"
                                        VerticalAlignment="Top"
                                        Fill="{Binding CurrentThreatBrush}" />

                                </StackPanel>
                                <TextBlock Margin="0,5,0,5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Text="{Binding PrimaryTargetShortText}" />
                            </StackPanel>
                        </Border>

                        <!-- 상황 분석 패널:
                         향후 VLM 분석 문장을 실시간으로 누적 표시할 영역이다. -->
                        <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,14,18,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock Style="{StaticResource PanelTitle}" Text="{Binding Text[AnalysisPanel]}" />
                                </Grid>
                                <ListBox Grid.Row="1"
                                     Margin="0,10,0,0"
                                     ItemsSource="{Binding DetectionTargets}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                Padding="10"
                                                Background="{DynamicResource DrawerItemBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="64"
                                                        Height="48"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="1">
                                                        <Image Source="{Binding Thumbnail}"
                                                            Stretch="UniformToFill" />
                                                    </Border>
                                                    <Grid Grid.Column="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                                            FontSize="13"
                                                            FontWeight="Bold"
                                                            Text="{Binding ClassName}" />
                                                        <TextBlock Grid.Row="1"
                                                            Margin="0,4,0,0"
                                                            Foreground="{DynamicResource SecondaryTextBrush}"
                                                            FontSize="11"
                                                            Text="{Binding ObjectId, StringFormat='ID {0}'}" />
                                                        <StackPanel Grid.Row="2"
                                                            Margin="0,5,0,0"
                                                            Orientation="Horizontal">
                                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                                FontSize="11"
                                                                Text="{Binding ScoreText}" />
                                                            <TextBlock Margin="10,0,0,0"
                                                                Foreground="{Binding ThreatBrush}"
                                                                FontSize="11"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding ThreatLevel}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- 시스템 로그 패널:
                         중요한 모드 변경과 상태 경고 이벤트만 남기는 운용 로그 영역이다. -->
                        <Border Grid.Row="2"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,14,18,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource PanelTitle}" Text="{Binding Text[SystemLog]}" />
                                    <Button Grid.Column="1"
                                        Padding="10,4"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TopBarSmallButton}"
                                        Command="{Binding SaveSystemLogsCommand}"
                                        Content="{Binding Text[Save]}" />
                                </Grid>
                                <ListBox Grid.Row="1"
                                     Margin="0,10,0,0"
                                     ItemsSource="{Binding SystemLogs}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="{DynamicResource DrawerItemBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                                <StackPanel>
                                                    <TextBlock Foreground="{DynamicResource WarningBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Time}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="14"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border x:Name="RecordedVideosPanel"
                Margin="64"
                Padding="18"
                Background="{DynamicResource DrawerBrush}"
                BorderBrush="{DynamicResource DrawerBorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Visibility="Collapsed"
                Panel.ZIndex="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="{DynamicResource DrawerTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Text[RecordedVideos]}" />
                            <TextBlock x:Name="RecordedVideosStatusText"
                                   Margin="16,5,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="13"
                                   Text="" />
                        </StackPanel>
                        <Button Grid.Column="1"
                            Width="82"
                            Padding="6,4"
                            FontSize="12"
                            Click="RefreshRecordedVideosButton_OnClick"
                            Style="{StaticResource TopBarButton}"
                            Content="{Binding Text[Refresh]}" />
                        <Button Grid.Column="3"
                            Width="70"
                            Padding="6,4"
                            FontSize="12"
                            Click="CloseRecordedVideosButton_OnClick"
                            Style="{StaticResource TopBarButton}"
                            Content="{Binding Text[Close]}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                            Padding="12"
                            Background="{DynamicResource OverlayPanelBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Text="{Binding Text[SavedVideos]}" />
                                <ListBox x:Name="RecordedVideoList"
                                      Grid.Row="1"
                                      Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                     SelectionChanged="RecordedVideoList_OnSelectionChanged"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryTextBrush}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                            Padding="12"
                            Background="{DynamicResource OverlayPanelBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="52" />
                                </Grid.RowDefinitions>
                                <Grid x:Name="RecordedVideoViewport"
                                  Grid.Row="0"
                                  Background="#FF000000"
                                  ClipToBounds="True"
                                  MouseWheel="RecordedVideoViewport_OnMouseWheel"
                                  MouseLeftButtonDown="RecordedVideoViewport_OnMouseLeftButtonDown"
                                  MouseMove="RecordedVideoViewport_OnMouseMove"
                                  MouseLeftButtonUp="RecordedVideoViewport_OnMouseLeftButtonUp">
                                    <MediaElement x:Name="RecordedVideoPlayer"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="Uniform"
                                              ScrubbingEnabled="True"
                                              RenderTransformOrigin="0.5,0.5"
                                              MediaOpened="RecordedVideoPlayer_OnMediaOpened"
                                              MediaEnded="RecordedVideoPlayer_OnMediaEnded"
                                              MediaFailed="RecordedVideoPlayer_OnMediaFailed"
                                              Volume="0.9">
                                        <MediaElement.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="RecordedVideoScaleTransform" ScaleX="1" ScaleY="1" />
                                                <TranslateTransform x:Name="RecordedVideoTranslateTransform" X="0" Y="0" />
                                            </TransformGroup>
                                        </MediaElement.RenderTransform>
                                    </MediaElement>

                                    <Border x:Name="RecordedVideoZoomMiniMap"
                                        Width="142"
                                        Height="92"
                                        Margin="12"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Background="#CC111827"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Visibility="Collapsed">
                                        <Grid Margin="10">
                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   Text="Zoom" />
                                            <Canvas Width="120"
                                                Height="62"
                                                Margin="0,18,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top">
                                                <Rectangle Width="120"
                                                       Height="62"
                                                       Fill="#55333F4D"
                                                       Stroke="#FF64748B"
                                                       StrokeThickness="1" />
                                                <Rectangle x:Name="RecordedVideoMiniMapViewport"
                                                       Width="120"
                                                       Height="62"
                                                       Fill="#2200FFAA"
                                                       Stroke="{DynamicResource AccentBrush}"
                                                       StrokeThickness="1.5" />
                                            </Canvas>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="58" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="RecordedVideoCurrentTimeText"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"
                                           Text="00:00" />
                                    <Slider x:Name="RecordedVideoPositionSlider"
                                        Grid.Column="1"
                                        Margin="10,0"
                                        Height="22"
                                        Minimum="0"
                                        Maximum="1"
                                        Style="{x:Null}"
                                        ValueChanged="RecordedVideoPositionSlider_OnValueChanged"
                                        PreviewMouseLeftButtonDown="RecordedVideoPositionSlider_OnPreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="RecordedVideoPositionSlider_OnPreviewMouseLeftButtonUp" />
                                    <TextBlock x:Name="RecordedVideoDurationText"
                                           Grid.Column="2"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"
                                           Text="00:00" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="138" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                        Click="RecordedVideoPlayButton_OnClick"
                                        Style="{StaticResource PlaybackIconButton}">
                                        <materialDesign:PackIcon Kind="Play" Width="22" Height="22" />
                                    </Button>
                                    <Button Grid.Column="2"
                                        Click="RecordedVideoPauseButton_OnClick"
                                        Style="{StaticResource PlaybackIconButton}">
                                        <materialDesign:PackIcon Kind="Pause" Width="22" Height="22" />
                                    </Button>
                                    <Button Grid.Column="4"
                                        Click="RecordedVideoStopButton_OnClick"
                                        Style="{StaticResource PlaybackIconButton}">
                                        <materialDesign:PackIcon Kind="Stop" Width="22" Height="22" />
                                    </Button>
                                    <StackPanel Grid.Column="5"
                                            Margin="12,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                        <TextBlock Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                   Text="Zoom" />
                                        <Button x:Name="RecordedVideoZoomResetButton"
                                            Width="58"
                                            Height="28"
                                            Padding="4,0"
                                            Click="RecordedVideoZoomResetButton_OnClick"
                                            Style="{StaticResource TopBarSmallButton}"
                                            Content="x1.00" />
                                        <Slider x:Name="RecordedVideoZoomSlider"
                                            Width="120"
                                            Margin="8,0,0,0"
                                            Minimum="1"
                                            Maximum="4"
                                            Value="1"
                                            TickFrequency="0.1"
                                            Style="{x:Null}"
                                            ValueChanged="RecordedVideoZoomSlider_OnValueChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="6"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                        <TextBlock Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                   Text="Speed" />
                                        <ComboBox x:Name="PlaybackSpeedCombo"
                                              Width="82"
                                              SelectedIndex="3"
                                              SelectionChanged="PlaybackSpeedCombo_OnSelectionChanged"
                                              VerticalAlignment="Center"
                                              Height="34"
                                              Padding="8,3"
                                              Foreground="White"
                                              Background="#22313A46"
                                              BorderBrush="{DynamicResource PanelBorderBrush}">
                                            <ComboBox.Resources>
                                                <Style TargetType="{x:Type ComboBoxItem}">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Background" Value="#FF1F2937" />
                                                    <Setter Property="Padding" Value="8,4" />
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBoxItem Tag="0.25" Content="0.25x" />
                                            <ComboBoxItem Tag="0.5" Content="0.5x" />
                                            <ComboBoxItem Tag="0.75" Content="0.75x" />
                                            <ComboBoxItem Tag="1" Content="1.0x" />
                                            <ComboBoxItem Tag="1.5" Content="1.5x" />
                                            <ComboBoxItem Tag="2" Content="2.0x" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Visibility="{Binding IsMotorDetailsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Panel.ZIndex="19">
                <Rectangle Fill="#66000000"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           IsHitTestVisible="True"
                           MouseLeftButtonDown="MotorDetailsBackdrop_OnMouseLeftButtonDown" />
                <Border Width="720"
                    MaxHeight="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="22"
                    Background="{DynamicResource DrawerBrush}"
                    BorderBrush="{DynamicResource DrawerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Effect="{StaticResource DrawerShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{DynamicResource DrawerTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="{Binding Text[MotorPosition]}" />
                            <Button Grid.Column="1"
                                Width="34"
                                Height="30"
                                Command="{Binding CloseMotorDetailsCommand}"
                                Style="{StaticResource PlaybackIconButton}">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                Padding="12"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Text="Pan Motor" />
                                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding PanMotorStatusItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Text="{Binding Name}"
                                                               TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="{Binding Value}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                Padding="12"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Text="Tilt Motor" />
                                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding TiltMotorStatusItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Text="{Binding Name}"
                                                               TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="{Binding Value}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- SettingsBackdrop은 설정창 뒤 배경을 어둡게 깔고 바깥 클릭 시 닫히는 오버레이다. -->
            <Rectangle x:Name="SettingsBackdrop"
                   Fill="#22000000"
                   Opacity="0"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   Panel.ZIndex="20"
                   MouseLeftButtonDown="SettingsBackdrop_OnMouseLeftButtonDown" />

            <!-- 설정 드로어.
             오른쪽 슬라이드 패널이며 주 탐지체, 테마, 언어, 화면 모드, 네트워크 설정을 담는다. -->
            <Border x:Name="SettingsDrawer"
                Width="280"
                Margin="0,12,12,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource DrawerBrush}"
                BorderBrush="{DynamicResource DrawerBorderBrush}"
                BorderThickness="1"
                Padding="22"
                Effect="{StaticResource DrawerShadow}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                Opacity="0"
                Visibility="Collapsed"
                Panel.ZIndex="21">
                <Border.RenderTransform>
                    <!-- 기본 위치는 화면 오른쪽 바깥이며 열릴 때 왼쪽으로 부드럽게 이동한다. -->
                    <TranslateTransform x:Name="SettingsDrawerTransform" X="320" />
                </Border.RenderTransform>
                <Border.CacheMode>
                    <BitmapCache RenderAtScale="1" />
                </Border.CacheMode>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Text[Settings]}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource DrawerTextBrush}" />

                    <ScrollViewer Grid.Row="1"
                        Margin="0,14,0,0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Margin="0,0,0,8"
                                BorderBrush="{DynamicResource DrawerBorderBrush}"
                                BorderThickness="0,0,0,2">
                                <TextBlock Margin="0,0,0,7"
                                    Text="{Binding Text[PrimaryTargetChange]}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource DrawerTextBrush}" />
                            </Border>

                            <Button Margin="0,0,0,6"
                                Command="{Binding SelectPrimaryTargetCommand}"
                                CommandParameter="복합"
                                Style="{StaticResource SettingsActionButton}"
                                Content="{Binding Text[TargetComposite]}" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,6,6"
                                    Command="{Binding SelectPrimaryTargetCommand}"
                                    CommandParameter="사람"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[TargetPerson]}" />
                                <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,0,6"
                                    Command="{Binding SelectPrimaryTargetCommand}"
                                    CommandParameter="무기체계"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[TargetWeapon]}" />
                                <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Command="{Binding SelectPrimaryTargetCommand}"
                                    CommandParameter="통신 장비"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[TargetComm]}" />
                                <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Command="{Binding SelectPrimaryTargetCommand}"
                                    CommandParameter="비군사 표적"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[TargetCivil]}" />
                            </Grid>

                            <Border Margin="0,10,0,8"
                                BorderBrush="{DynamicResource DrawerBorderBrush}"
                                BorderThickness="0,1,0,0">
                                <TextBlock Margin="0,9,0,0"
                                    Text="{Binding Text[ThemeChange]}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource DrawerTextBrush}" />
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Command="{Binding SetThemeCommand}"
                                    CommandParameter="Dark"
                                    Opacity="{Binding DarkThemeButtonOpacity}"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[DarkTheme]}" />
                                <Button Grid.Column="1"
                                    Command="{Binding SetThemeCommand}"
                                    CommandParameter="Light"
                                    Opacity="{Binding LightThemeButtonOpacity}"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[LightTheme]}" />
                            </Grid>

                            <Border Margin="0,12,0,8"
                                BorderBrush="{DynamicResource DrawerBorderBrush}"
                                BorderThickness="0,1,0,0">
                                <TextBlock Margin="0,9,0,0"
                                    Text="{Binding Text[LanguageChange]}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource DrawerTextBrush}" />
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Command="{Binding SetLanguageCommand}"
                                    CommandParameter="English"
                                    Opacity="{Binding EnglishLanguageButtonOpacity}"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[English]}" />
                                <Button Grid.Column="1"
                                    Command="{Binding SetLanguageCommand}"
                                    CommandParameter="Korean"
                                    Opacity="{Binding KoreanLanguageButtonOpacity}"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding Text[Korean]}" />
                            </Grid>

                            <Border Margin="0,12,0,8"
                                BorderBrush="{DynamicResource DrawerBorderBrush}"
                                BorderThickness="0,1,0,0">
                                <TextBlock Margin="0,9,0,0"
                                    Text="{Binding Text[ScreenMode]}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource DrawerTextBrush}" />
                            </Border>

                            <Button x:Name="WindowModeToggleButton"
                                Click="WindowModeToggleButton_OnClick"
                                Style="{StaticResource SettingsActionButton}"
                                Content="{Binding Text[WindowMode]}" />

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Window>
